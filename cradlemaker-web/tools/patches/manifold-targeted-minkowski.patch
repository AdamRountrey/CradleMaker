+struct MinDistanceDetails {
+  double distanceSquared = std::numeric_limits<double>::infinity();
+  int tri = -1;
+  int triOther = -1;
+  vec3 centroid = vec3(0.0);
+  vec3 centroidOther = vec3(0.0);
+  std::array<int64_t, 3> targetCell = {0, 0, 0};
+};
+
+struct MinDistanceDetailsRecorder {
+  using Local = MinDistanceDetails;
+  const Manifold::Impl &self, &other;
+#if MANIFOLD_PAR == 1
+  tbb::combinable<Local> store;
+  Local& local() { return store.local(); }
+  Local get() {
+    Local result;
+    store.combine_each([&](const Local& value) {
+      if (value.distanceSquared < result.distanceSquared) result = value;
+    });
+    return result;
+  }
+#else
+  Local result;
+  Local& local() { return result; }
+  Local get() { return result; }
+#endif
+
+  void record(int triOther, int tri, Local& closest) {
+    std::array<vec3, 3> p;
+    std::array<vec3, 3> q;
+    for (const int j : {0, 1, 2}) {
+      p[j] = self.vertPos_[self.halfedge_.Start(3 * tri + j)];
+      q[j] = other.vertPos_[other.halfedge_.Start(3 * triOther + j)];
+    }
+    const double distanceSquared = DistanceTriangleTriangleSquared(p, q);
+    if (!(distanceSquared < closest.distanceSquared)) return;
+
+    closest.distanceSquared = distanceSquared;
+    closest.tri = tri;
+    closest.triOther = triOther;
+    closest.centroid = (p[0] + p[1] + p[2]) / 3.0;
+    closest.centroidOther = (q[0] + q[1] + q[2]) / 3.0;
+  }
+};
+
+bool MinDistanceDetailsLess(const MinDistanceDetails& a,
+                            const MinDistanceDetails& b) {
+  if (a.distanceSquared != b.distanceSquared) {
+    return a.distanceSquared < b.distanceSquared;
+  }
+  if (a.tri != b.tri) return a.tri < b.tri;
+  return a.triOther < b.triOther;
+}
+
+struct MinDistanceDetailsManyRecorder {
+  using Local = std::vector<MinDistanceDetails>;
+  const Manifold::Impl &self, &other;
+  size_t maxResults;
+  double maxDistanceSquared;
+  vec3 targetCellSize;
+  vec3 targetBoundsMin;
+#if MANIFOLD_PAR == 1
+  tbb::combinable<Local> store;
+  Local& local() { return store.local(); }
+  Local get() {
+    Local result;
+    store.combine_each([&](const Local& values) {
+      for (const MinDistanceDetails& value : values) Insert(result, value);
+    });
+    return result;
+  }
+#else
+  Local result;
+  Local& local() { return result; }
+  Local get() { return result; }
+#endif
+
+  void Insert(Local& details, const MinDistanceDetails& candidate) const {
+    MinDistanceDetails best = candidate;
+    bool clustered = false;
+    for (size_t i = 0; i < details.size();) {
+      if (details[i].targetCell == candidate.targetCell) {
+        if (MinDistanceDetailsLess(details[i], best)) best = details[i];
+        details.erase(details.begin() + i);
+        clustered = true;
+      } else {
+        ++i;
+      }
+    }
+
+    if (clustered || details.size() < maxResults) {
+      details.push_back(best);
+    } else if (MinDistanceDetailsLess(candidate, details.back())) {
+      details.back() = candidate;
+    } else {
+      return;
+    }
+    std::sort(details.begin(), details.end(), MinDistanceDetailsLess);
+  }
+
+  void record(int triOther, int tri, Local& details) {
+    std::array<vec3, 3> p;
+    std::array<vec3, 3> q;
+    for (const int j : {0, 1, 2}) {
+      p[j] = self.vertPos_[self.halfedge_.Start(3 * tri + j)];
+      q[j] = other.vertPos_[other.halfedge_.Start(3 * triOther + j)];
+    }
+    const double distanceSquared = DistanceTriangleTriangleSquared(p, q);
+    if (!std::isfinite(distanceSquared) ||
+        distanceSquared > maxDistanceSquared) {
+      return;
+    }
+
+    const vec3 centroid = (p[0] + p[1] + p[2]) / 3.0;
+    const vec3 centroidOther = (q[0] + q[1] + q[2]) / 3.0;
+    std::array<int64_t, 3> targetCell;
+    for (int axis = 0; axis < 3; ++axis) {
+      targetCell[axis] = static_cast<int64_t>(std::floor(
+          (centroidOther[axis] - targetBoundsMin[axis]) /
+              targetCellSize[axis] +
+          1e-12));
+    }
+    Insert(details,
+           {distanceSquared, tri, triOther, centroid, centroidOther,
+            targetCell});
+  }
+};
