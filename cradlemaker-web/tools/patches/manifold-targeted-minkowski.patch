+/**
+ * Difference a target against retained swept hulls in bounded batches.
+ * `remaining` has already had the unexpanded source model subtracted so solid
+ * overlap and target-inside-model cases remain covered.
+ */
+Manifold Manifold::Impl::MinkowskiSubtractTarget(
+    const Impl& kernel, const Impl& target, Manifold remaining,
+    ExecutionContext::Impl* ctx,
+    const std::function<void(size_t, size_t, size_t, Error, double, double,
+                             size_t)>& progress,
+    size_t initialBatchSize) const {
+  auto withStatus = [](Error status) {
+    auto impl = std::make_shared<Impl>();
+    impl->status_ = status;
+    return Manifold(impl);
+  };
+  auto evalBatch = [ctx](std::vector<Manifold>&& items, OpType op) {
+    Manifold tree = Manifold::BatchBoolean(items, op);
+    tree.GetCsgLeafNode(ctx);
+    return tree;
+  };
+  if (IsCancelled(ctx)) return withStatus(Error::Cancelled);
+  if (remaining.IsEmpty() || kernel.IsEmpty()) return remaining;
+
+  const std::vector<size_t> targetFaces =
+      MinkowskiTargetFaces(kernel, target, ctx);
+  if (IsCancelled(ctx)) return withStatus(Error::Cancelled);
+  const VecView<vec3> verts = kernel.vertPos_;
+  const size_t totalFaces = targetFaces.size();
+  if (progress) {
+    progress(0, totalFaces, 0, Error::NoError, 0.0, 0.0,
+             remaining.NumTri());
+  }
+  if (totalFaces == 0) return remaining;
+
+  // Large targets retain expensive Boolean state alongside each hull union.
+  // Start them at half the normal batch size, then split a failed batch until
+  // it succeeds or reaches the minimum useful unit.
+  constexpr size_t DEFAULT_BATCH_SIZE = 8000;
+  constexpr size_t LARGE_TARGET_BATCH_SIZE = 4000;
+  constexpr size_t MIN_RETRY_BATCH_SIZE = 250;
+  const bool largeOperation = NumTri() > 1000000 || target.NumTri() > 1000000;
+  const size_t defaultBatchSize =
+      largeOperation ? LARGE_TARGET_BATCH_SIZE : DEFAULT_BATCH_SIZE;
+  const size_t streamBatchSize = initialBatchSize == 0
+      ? defaultBatchSize
+      : std::clamp(initialBatchSize, MIN_RETRY_BATCH_SIZE,
+                   DEFAULT_BATCH_SIZE);
+  size_t completedFaces = 0;
+  Manifold failure;
+  using BatchClock = std::chrono::steady_clock;
+  auto elapsedMs = [](BatchClock::time_point started) {
+    return std::chrono::duration<double, std::milli>(BatchClock::now() -
+                                                     started)
+        .count();
+  };
+
+  std::function<bool(size_t, size_t)> subtractRange;
+  subtractRange = [&](size_t offset, size_t count) {
+    if (IsCancelled(ctx)) {
+      failure = withStatus(Error::Cancelled);
+      return false;
+    }
+
+    const auto hullStarted = BatchClock::now();
+    std::vector<Manifold> hulls(count);
+    for_each_n(autoPolicy(count, 100), countAt(0), count,
+               [&hulls, this, &verts, &targetFaces, offset](const int iter) {
+                 std::vector<vec3> simpleHull;
+                 simpleHull.reserve(verts.size() * 3);
+                 const size_t face = targetFaces[offset + iter];
+                 for (const int i : {0, 1, 2}) {
+                   const int edge = static_cast<int>(face * 3) + i;
+                   const vec3 vertex = vertPos_[halfedge_.Start(edge)];
+                   auto translate = [vertex](vec3 value) {
+                     return value + vertex;
+                   };
+                   simpleHull.insert(
+                       simpleHull.end(),
+                       TransformIterator(verts.begin(), translate),
+                       TransformIterator(verts.end(), translate));
+                 }
+                 hulls[iter] = Manifold::Hull(simpleHull);
+               });
+
+    Manifold batch = evalBatch(std::move(hulls), OpType::Add);
+    const double hullUnionMs = elapsedMs(hullStarted);
+    double differenceMs = 0.0;
+    Error status = batch.Status();
+    if (status == Error::NoError) {
+      const auto differenceStarted = BatchClock::now();
+      std::vector<Manifold> difference;
+      difference.reserve(2);
+      difference.push_back(remaining);
+      difference.push_back(std::move(batch));
+      Manifold next = evalBatch(std::move(difference), OpType::Subtract);
+      differenceMs = elapsedMs(differenceStarted);
+      status = next.Status();
+      if (status == Error::NoError) {
+        remaining = std::move(next);
+        completedFaces += count;
+        if (progress) {
+          progress(completedFaces, totalFaces, count, Error::NoError,
+                   hullUnionMs, differenceMs, remaining.NumTri());
+        }
+        return true;
+      }
+    }
+
+    batch = Manifold();
+    if (progress) {
+      progress(completedFaces, totalFaces, count, status, hullUnionMs,
+               differenceMs, remaining.NumTri());
+    }
+    if (status != Error::Cancelled && count > MIN_RETRY_BATCH_SIZE) {
+      const size_t left = count / 2;
+      return subtractRange(offset, left) &&
+             subtractRange(offset + left, count - left);
+    }
+    failure = withStatus(status);
+    return false;
+  };
+
+  for (size_t offset = 0; offset < totalFaces;
+       offset += streamBatchSize) {
+    const size_t count = std::min(totalFaces - offset, streamBatchSize);
+    if (!subtractRange(offset, count)) return failure;
+    if (remaining.IsEmpty()) {
+      completedFaces = totalFaces;
+      if (progress) {
+        progress(totalFaces, totalFaces, 0, Error::NoError, 0.0, 0.0, 0);
+      }
+      break;
+    }
+  }
+  return remaining;
+}
