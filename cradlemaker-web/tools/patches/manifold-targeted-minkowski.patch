+  for (const vec3& vertex : kernel.vertPos_) {
+    const vec3 normalized = vertex * inverseKernelScale;
+    normalizedKernelRadiusSquared = std::max(
+        normalizedKernelRadiusSquared, la::dot(normalized, normalized));
+  }
+  const double normalizedPadding =
+      padding * (std::abs(inverseKernelScale.x) +
+                 std::abs(inverseKernelScale.y) +
+                 std::abs(inverseKernelScale.z));
+  const double normalizedDistanceLimit =
+      std::sqrt(normalizedKernelRadiusSquared) + normalizedPadding;
+  const double normalizedDistanceLimitSquared =
+      normalizedDistanceLimit * normalizedDistanceLimit;
+
+  std::vector<uint8_t> overlaps(numTri, 0);
+  auto sweptFaceBox = [this, &kernel, pad](const int face) {
+    Box triangle;
+    for (const int i : {0, 1, 2}) {
+      triangle.Union(vertPos_[halfedge_.Start(face * 3 + i)]);
+    }
+    Box swept;
+    swept.min = triangle.min + kernel.bBox_.min - pad;
+    swept.max = triangle.max + kernel.bBox_.max + pad;
+    return swept;
+  };
+  auto markOverlap = [this, &target, &overlaps, useDistanceFilter,
+                      inverseKernelScale,
+                      normalizedDistanceLimitSquared](const int queryIdx,
+                                                      const int targetFace) {
+    if (overlaps[queryIdx] != 0) return;
+    if (!useDistanceFilter) {
+      overlaps[queryIdx] = 1;
+      return;
+    }
+
+    std::array<vec3, 3> sourceTriangle;
+    std::array<vec3, 3> targetTriangle;
+    for (const int i : {0, 1, 2}) {
+      sourceTriangle[i] =
+          vertPos_[halfedge_.Start(queryIdx * 3 + i)] * inverseKernelScale;
+      targetTriangle[i] =
+          target.vertPos_[target.halfedge_.Start(targetFace * 3 + i)] *
+          inverseKernelScale;
+    }
+    if (TriangleSeparationLowerBoundSquared(sourceTriangle, targetTriangle) <=
+        normalizedDistanceLimitSquared) {
+      overlaps[queryIdx] = 1;
+    }
+  };
+  auto recorder = MakeSimpleRecorder(markOverlap);
+  // Sequential recording avoids concurrent writes when one query overlaps
+  // several target leaves. The BVH traversal still removes the dominant work.
+  target.collider_.Collisions(recorder, sweptFaceBox,
+                              static_cast<int>(numTri), false, ctx);
+  if (IsCancelled(ctx)) return {};
+
+  // Surface-distance hits do not cover the case where an entire swept hull
+  // lies inside the target. Test one guaranteed interior point of each
+  // remaining convex swept hull against the target winding number. The average
+  // kernel vertex is inside its convex hull, so adding it to the triangle
+  // centroid is inside the triangle/kernel Minkowski hull.
+  vec3 kernelInterior(0.0);
+  for (const vec3& vertex : kernel.vertPos_) kernelInterior += vertex;
+  kernelInterior /= static_cast<double>(kernel.vertPos_.size());
+  std::vector<vec3> containmentPoints;
+  std::vector<size_t> containmentFaces;
+  containmentPoints.reserve(numTri);
+  containmentFaces.reserve(numTri);
+  for (size_t face = 0; face < numTri; ++face) {
+    if (overlaps[face] != 0) continue;
+    const Box swept = sweptFaceBox(static_cast<int>(face));
+    if (!swept.DoesOverlap(target.bBox_)) continue;
+
+    vec3 triangleCenter(0.0);
+    for (const int i : {0, 1, 2}) {
+      triangleCenter += vertPos_[halfedge_.Start(
+          static_cast<int>(face * 3) + i)];
+    }
+    containmentPoints.push_back(triangleCenter / 3.0 + kernelInterior);
+    containmentFaces.push_back(face);
+  }
+  if (!containmentPoints.empty()) {
+    const Vec<int> winding = target.PointWinding(VecView<const vec3>(
+        containmentPoints.data(), containmentPoints.size()));
+    for (size_t i = 0; i < containmentFaces.size(); ++i) {
+      if (winding[i] != 0) overlaps[containmentFaces[i]] = 1;
+    }
+  }
+  if (IsCancelled(ctx)) return {};
+
+  candidates.reserve(numTri);
+  for (size_t face = 0; face < numTri; ++face) {
+    if (overlaps[face] != 0) candidates.push_back(face);
+  }
+  return candidates;
+}
