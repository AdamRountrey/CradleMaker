+double ProjectedSeparationSquared(const std::array<vec3, 3>& a,
+                                  const std::array<vec3, 3>& b,
+                                  const vec3& axis) {
+  const double axisLengthSquared = la::dot(axis, axis);
+  if (!(axisLengthSquared > 1e-24) || !std::isfinite(axisLengthSquared)) {
+    return 0.0;
+  }
+
+  double minA = la::dot(a[0], axis);
+  double maxA = minA;
+  double minB = la::dot(b[0], axis);
+  double maxB = minB;
+  for (const int i : {1, 2}) {
+    const double projectedA = la::dot(a[i], axis);
+    const double projectedB = la::dot(b[i], axis);
+    minA = std::min(minA, projectedA);
+    maxA = std::max(maxA, projectedA);
+    minB = std::min(minB, projectedB);
+    maxB = std::max(maxB, projectedB);
+  }
+  const double separation =
+      std::max({0.0, minA - maxB, minB - maxA});
+  if (!std::isfinite(separation)) return 0.0;
+  return separation * separation / axisLengthSquared;
+}
+
+double TriangleSeparationLowerBoundSquared(
+    const std::array<vec3, 3>& a, const std::array<vec3, 3>& b) {
+  const std::array<vec3, 3> edgesA = {
+      a[1] - a[0], a[2] - a[1], a[0] - a[2]};
+  const std::array<vec3, 3> edgesB = {
+      b[1] - b[0], b[2] - b[1], b[0] - b[2]};
+  const vec3 normalA = la::cross(edgesA[0], edgesA[1]);
+  const vec3 normalB = la::cross(edgesB[0], edgesB[1]);
+  double lowerBoundSquared = 0.0;
+  auto includeAxis = [&](const vec3& axis) {
+    lowerBoundSquared = std::max(
+        lowerBoundSquared, ProjectedSeparationSquared(a, b, axis));
+  };
+
+  includeAxis(vec3(1.0, 0.0, 0.0));
+  includeAxis(vec3(0.0, 1.0, 0.0));
+  includeAxis(vec3(0.0, 0.0, 1.0));
+  includeAxis(normalA);
+  includeAxis(normalB);
+  for (const vec3& edgeA : edgesA) {
+    includeAxis(la::cross(normalA, edgeA));
+    for (const vec3& edgeB : edgesB) {
+      includeAxis(la::cross(edgeA, edgeB));
+    }
+  }
+  for (const vec3& edgeB : edgesB) {
+    includeAxis(la::cross(normalB, edgeB));
+  }
+  return lowerBoundSquared;
+}
