+size_t Manifold::MinkowskiTargetAabbCandidateCount(
+    const Manifold& kernel, const Manifold& target) const {
+  auto ctx = std::atomic_load(&ctx_);
+  auto aImpl = GetCsgLeafNode(ctx.get()).GetImpl();
+  auto bImpl = kernel.GetCsgLeafNode(ctx.get()).GetImpl();
+  auto targetImpl = target.GetCsgLeafNode(ctx.get()).GetImpl();
+  if (aImpl->status_ != Error::NoError || bImpl->status_ != Error::NoError ||
+      targetImpl->status_ != Error::NoError || aImpl->IsEmpty() ||
+      bImpl->IsEmpty() || targetImpl->IsEmpty()) {
+    return 0;
+  }
+
+  bool aConvex = aImpl->IsConvex();
+  bool bConvex = bImpl->IsConvex();
+  if (aConvex && !bConvex) {
+    std::swap(aImpl, bImpl);
+    std::swap(aConvex, bConvex);
+  }
+  if (!aConvex && bConvex) {
+    return aImpl->MinkowskiTargetFaces(*bImpl, *targetImpl, ctx.get(), false)
+        .size();
+  }
+  return aImpl->NumTri();
