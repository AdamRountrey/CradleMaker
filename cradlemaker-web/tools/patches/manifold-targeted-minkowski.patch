+/**
+ * Compute only the portion of a Minkowski sum that can intersect target.
+ *
+ * The result is equivalent to MinkowskiSum(kernel) when subsequently
+ * intersected with or subtracted from target. Geometry away from target may be
+ * omitted.
+ */
+Manifold Manifold::MinkowskiSumTargeted(const Manifold& kernel,
+                                        const Manifold& target) const {
+  auto ctx = std::atomic_load(&ctx_);
+  auto aImpl = GetCsgLeafNode(ctx.get()).GetImpl();
+  if (aImpl->status_ != Error::NoError) return PropagateStatus(aImpl->status_);
+  auto bImpl = kernel.GetCsgLeafNode(ctx.get()).GetImpl();
+  if (bImpl->status_ != Error::NoError) return PropagateStatus(bImpl->status_);
+  auto targetImpl = target.GetCsgLeafNode(ctx.get()).GetImpl();
+  if (targetImpl->status_ != Error::NoError) {
+    return PropagateStatus(targetImpl->status_);
+  }
+  return aImpl->Minkowski(*bImpl, false, ctx.get(), targetImpl.get());
+}
+
+/**
+ * Subtract the target-relevant Minkowski sweep directly from target.
+ *
+ * Unlike MinkowskiSumTargeted(), this never materializes the union of every
+ * retained swept hull. The target is differenced in bounded batches using
+ * target - union(H_i) = (...((target - H_1) - H_2) ...).
+ */
+Manifold Manifold::MinkowskiSubtractTargeted(
+    const Manifold& kernel, const Manifold& target,
+    std::function<void(size_t, size_t, size_t, Error, double, double, size_t)>
+        progress,
+    size_t initialBatchSize) const {
+  auto ctx = std::atomic_load(&ctx_);
+  auto aImpl = GetCsgLeafNode(ctx.get()).GetImpl();
+  if (aImpl->status_ != Error::NoError) return PropagateStatus(aImpl->status_);
+  auto bImpl = kernel.GetCsgLeafNode(ctx.get()).GetImpl();
+  if (bImpl->status_ != Error::NoError) return PropagateStatus(bImpl->status_);
+  auto targetImpl = target.GetCsgLeafNode(ctx.get()).GetImpl();
+  if (targetImpl->status_ != Error::NoError) {
+    return PropagateStatus(targetImpl->status_);
+  }
+
+  if (targetImpl->IsEmpty() || aImpl->IsEmpty()) return target;
+  if (!aImpl->IsConvex() && bImpl->IsConvex()) {
+    Manifold remaining = target.Boolean(*this, OpType::Subtract);
+    auto remainingImpl = remaining.GetCsgLeafNode(ctx.get()).GetImpl();
+    if (remainingImpl->status_ != Error::NoError) {
+      return PropagateStatus(remainingImpl->status_);
+    }
+    return aImpl->MinkowskiSubtractTarget(
+        *bImpl, *remainingImpl, std::move(remaining), ctx.get(), progress,
+        initialBatchSize);
+  }
+
+  Manifold sweep = MinkowskiSumTargeted(kernel, target);
+  Manifold remaining = target.Boolean(sweep, OpType::Subtract);
+  auto remainingImpl = remaining.GetCsgLeafNode(ctx.get()).GetImpl();
+  if (remainingImpl->status_ != Error::NoError) {
+    return PropagateStatus(remainingImpl->status_);
+  }
+  return remaining;
+}
